// Finosuke — Prisma Schema (Phase 1 MVP — Clerk Auth)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// User profile & preferences — linked to Clerk by id (Clerk userId is the PK)
model User {
  id           String        @id  // Clerk userId (e.g. "user_2abc123...")
  email        String        @unique
  name         String?
  currency     String        @default("USD")
  locale       String        @default("en-US")
  timezone     String        @default("UTC")
  avatar       String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions      Transaction[]
  budgets           Budget[]
  categories        Category[]
  savingsGoals      SavingsGoal[]
  bills             Bill[]
  pushSubscriptions PushSubscription[]

  @@map("users")
}

model Category {
  id           String        @id @default(cuid())
  userId       String
  name         String
  icon         String        @default("circle")
  color        String        @default("#71717a")
  isDefault    Boolean       @default(false)
  createdAt    DateTime      @default(now())
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  budgets      Budget[]
  bills        Bill[]

  @@unique([userId, name])
  @@map("categories")
}

model Transaction {
  id          String    @id @default(cuid())
  userId      String
  amount      Float
  type        String    @default("expense") // "expense" | "income"
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])
  date        DateTime
  notes       String?
  tags        String[]  @default([])
  isRecurring Boolean   @default(false)
  recurringId String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([userId, type])
  @@map("transactions")
}

model Budget {
  id         String    @id @default(cuid())
  userId     String
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])
  name       String
  amount     Float
  period     String    @default("monthly") // "weekly" | "monthly"
  month      String // "2024-01" format
  rollover   Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId, month])
  @@index([userId, month])
  @@map("budgets")
}

model SavingsGoal {
  id            String    @id @default(cuid())
  userId        String
  name          String
  description   String?
  targetAmount  Float
  currentAmount Float     @default(0)
  targetDate    DateTime?
  icon          String    @default("🎯")
  color         String    @default("#f5c842")
  isCompleted   Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("savings_goals")
}

model Bill {
  id          String    @id @default(cuid())
  userId      String
  name        String
  amount      Float
  frequency   String    @default("monthly") // monthly|weekly|yearly|once
  dueDay      Int
  nextDueDate DateTime
  categoryId  String?
  notes       String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category    Category? @relation(fields: [categoryId], references: [id])

  @@index([userId])
  @@index([userId, nextDueDate])
  @@map("bills")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}
